generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model SheetSource {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  url       String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
